{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Expensia (Windows)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "deviceId": "windows"
    },
    {
      "name": "Expensia (Chrome - no CORS)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "deviceId": "chrome",
      "args": [
        "--web-port", "9090",
        "--web-browser-flag", "--disable-web-security",
        "--web-browser-flag", "--user-data-dir=C:\\Temp\\chrome-dev-expensia"
      ]
    }
  ]
}
